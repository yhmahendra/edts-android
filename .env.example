# Copy this file to .env and fill in the values before running the tests.
# Never commit .env to version control.

# ADB device identifier — get it from: adb devices -l
DEVICE_UDID=

# Device model name (for display purposes)
DEVICE_NAME=

# Android OS version (e.g. 16)
ANDROID_VERSION=

# App package name — get it from: adb shell pm list packages | grep indomaret
APP_PACKAGE=

# Appium server host and port (default: localhost:4723)
APPIUM_HOST=
APPIUM_PORT=

# Klik Indomaret test account credentials
USER_PHONE=
USER_PASSWORD=

# Product keyword used in the search step
SEARCH_KEYWORD=
