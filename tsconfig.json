{
  "compilerOptions": {
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "module": "ESNext",
    "target": "ESNext",
    "strict": true,
    "types": ["node", "@wdio/globals/types"],
    "paths": {
      "@config/*": ["./config/*"],
      "@pages/*": ["./test/pages/*"],
      "@support/*": ["./test/support/*"],
      "@data/*": ["./test/support/data/*"],
      "@steps/*": ["./test/steps/*"]
    }
  },
  "include": ["test/**/*.ts", "config/*.ts"],
  "exclude": ["node_modules"]
}
